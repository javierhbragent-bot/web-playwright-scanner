{
  "name": "web-playwright-scanner",
  "version": "0.1.0",
  "description": "Playwright-based web scanner that documents UI pages, API calls, and their relationships",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "web-scanner": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "nanoid": "^5.0.9",
    "pino": "^9.6.0",
    "playwright": "^1.49.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
